# ── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-3-5-haiku-20241022

# ── Canvas ────────────────────────────────────────────────────────────────────
CANVAS_URL=https://canvas.instructure.com
CANVAS_EMAIL=you@university.edu
CANVAS_PASSWORD=yourpassword

# ── Workday ───────────────────────────────────────────────────────────────────
WORKDAY_URL=https://wd5.myworkday.com/myuniversity
WORKDAY_EMAIL=you@university.edu
WORKDAY_PASSWORD=yourpassword

# ── Outlook / Microsoft 365 ───────────────────────────────────────────────────
OUTLOOK_EMAIL=you@university.edu
OUTLOOK_PASSWORD=yourpassword

# ── Bank ──────────────────────────────────────────────────────────────────────
BANK_URL=https://online.yourbank.com/login
BANK_USERNAME=yourusername
BANK_PASSWORD=yourpassword
OVERDRAFT_THRESHOLD=25.0

# ── Morning Briefing Delivery ─────────────────────────────────────────────────
NOTIFICATION_EMAIL=you@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-gmail-app-password

# ── Schedule (6:00 AM by default) ─────────────────────────────────────────────
BRIEFING_HOUR=6
BRIEFING_MINUTE=0
